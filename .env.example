# Caldwell — Speak through ElevenLabs
#
# Primary stores (preferred):
#   - ELEVENLABS_API_KEY   — macOS Keychain (service: caldwell-speak)
#   - ELEVENLABS_VOICE_ID  — config.json (gitignored)
# Both managed via the dashboard Settings panel (gear icon).
#
# This .env file is a dev-time override only. Real env vars (set in the
# shell) beat Keychain and config.json. Use it for CI / testing /
# experiments, not for routine config.

# ElevenLabs API key (optional — primary store is macOS Keychain)
ELEVENLABS_API_KEY=

# Default voice ID (optional — primary store is config.json)
ELEVENLABS_VOICE_ID=

# Cache directory for replayed audio (default: ./cache)
SPEAK_CACHE_DIR=

# HTTP port for daemon + dashboard (default: 7865)
SPEAK_PORT=

# Spend caps (free-tier protection). Defaults: 20 calls/min, 2000 chars/day.
# Set to 0 to disable a given cap.
SPEAK_RATE_LIMIT_PER_MIN=
SPEAK_DAILY_CHAR_CAP=
