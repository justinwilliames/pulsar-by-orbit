# Caldwell — Speak through ElevenLabs
#
# You can configure the API key and default voice ID either in this file
# OR via the dashboard Settings panel (gear icon, top-right) which writes
# to config.json. config.json takes precedence over .env. Real environment
# variables override both.

# ElevenLabs API key (required for TTS)
ELEVENLABS_API_KEY=

# Default voice ID (optional — falls back to Caldwell entry in voices.json)
ELEVENLABS_VOICE_ID=

# Cache directory for replayed audio (default: ./cache)
SPEAK_CACHE_DIR=

# HTTP port for daemon + dashboard (default: 7865)
SPEAK_PORT=
